<Window x:Class="Crime_analysis.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crime Analysis System"
        Height="500" Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL -->
        <Border Grid.Column="0" Background="#E74C3C">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="🔍"
                           FontSize="60"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="CRIME ANALYSIS"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <TextBlock Text="SYSTEM"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <Rectangle Height="2" Width="120"
                           Fill="White" Opacity="0.5"
                           Margin="0,15,0,15"/>
                <TextBlock Text="Advanced Analytics Platform"
                           FontSize="12"
                           Foreground="White" Opacity="0.8"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="For Law Enforcement"
                           FontSize="12"
                           Foreground="White" Opacity="0.8"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1"
                Background="#1E1E2E"
                Padding="40,30">
            <StackPanel VerticalAlignment="Center">

                <!-- Title -->
                <TextBlock Text="Welcome Back"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Sign in to continue"
                           FontSize="12"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,30"/>

                <!-- Username -->
                <TextBlock Text="USERNAME"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername"
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,20"/>

                <!-- Password -->
                <TextBlock Text="PASSWORD"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#AAAAAA"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,10"/>

                <!-- Error Message -->
                <TextBlock x:Name="txtError"
                           FontSize="11"
                           Foreground="#E74C3C"
                           Margin="0,0,0,20"
                           Visibility="Collapsed"/>

                <!-- Login Button -->
                <Button x:Name="btnLogin"
                        Content="LOGIN"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0"
                        Click="btnLogin_Click"/>

                <!-- Close -->
                <TextBlock Text="Exit Application"
                           FontSize="11"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="Exit_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>